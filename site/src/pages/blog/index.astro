---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const [latest, ...older] = posts;
const { Content } = latest ? await latest.render() : { Content: null };
---

<BaseLayout title="Blog — Arachne" description="Updates, guides, and announcements from the Arachne team.">
  <div class="max-w-7xl mx-auto px-4 sm:px-8 py-16 flex gap-12">
    {/* Main content — latest post rendered in full */}
    <article class="flex-1 min-w-0">
      <h1 class="text-3xl font-bold text-white mb-8">Blog</h1>

      {latest && (
        <div>
          <div class="flex items-center gap-3 text-sm text-gray-500 mb-3">
            <time datetime={latest.data.date.toISOString()}>
              {latest.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
            </time>
            <span>&middot;</span>
            <span>{latest.data.author}</span>
          </div>
          <h2 class="text-3xl font-bold text-white mb-3">{latest.data.title}</h2>
          <p class="text-lg text-gray-400 mb-6">{latest.data.description}</p>
          {latest.data.tags.length > 0 && (
            <div class="flex gap-2 mb-8">
              {latest.data.tags.map((tag: string) => (
                <span class="text-xs bg-indigo-950 text-indigo-300 border border-indigo-800 px-2 py-0.5 rounded-full">{tag}</span>
              ))}
            </div>
          )}
          <div class="prose-dark">
            {Content && <Content />}
          </div>
        </div>
      )}
    </article>

    {/* Sidebar — all posts list */}
    <aside class="hidden lg:block w-64 shrink-0">
      <nav class="sticky top-8">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-4">All Posts</h3>
        <div class="space-y-3">
          {posts.map(post => (
            <a
              href={`/blog/${post.slug}`}
              class:list={[
                'block rounded-lg p-3 transition-colors',
                post.slug === latest?.slug
                  ? 'bg-gray-800 border border-gray-700'
                  : 'hover:bg-gray-900',
              ]}
            >
              <h4 class:list={[
                'text-sm font-medium leading-snug',
                post.slug === latest?.slug ? 'text-white' : 'text-gray-400',
              ]}>
                {post.data.title}
              </h4>
              <time class="text-xs text-gray-600 mt-1 block" datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </a>
          ))}
        </div>
      </nav>
    </aside>
  </div>
</BaseLayout>
